---
---

<div class="intro-screen" id="intro">
  <div class="fog fog-a" aria-hidden="true"></div>
  <div class="fog fog-b" aria-hidden="true"></div>
  <div class="dust-field" aria-hidden="true">
    <span></span><span></span><span></span><span></span><span></span><span></span>
  </div>

  <div class="camera-rig" aria-label="GBP Home Art and Decors logo intro">
    <div class="logo-wrap">
      <div class="pulse-backdrop" aria-hidden="true"></div>
      <div class="monogram" aria-hidden="true">
        <span class="letter letter-g">G</span>
        <span class="letter letter-b">B</span>
        <span class="letter letter-p">P</span>
      </div>
      <div class="sweep-line" aria-hidden="true"></div>
      <p class="brand-subtitle">HOME ART &amp; DECORS</p>
    </div>
  </div>
</div>

<script>
  (() => {
    const intro = document.getElementById('intro');
    if (!intro) return;

    let finished = false;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const hideDelay = prefersReducedMotion ? 950 : 3950;
    const fallbackDoneDelay = prefersReducedMotion ? 1400 : 4600;

    const finishIntro = () => {
      if (finished) return;
      finished = true;
      intro.remove();
      window.dispatchEvent(new CustomEvent('gbp:intro-complete'));
    };

    setTimeout(() => {
      intro.classList.add('intro-hide');
    }, hideDelay);

    intro.addEventListener('animationend', (event) => {
      if ((event as AnimationEvent).animationName === 'fadeOutIntro') {
        finishIntro();
      }
    });

    setTimeout(finishIntro, fallbackDoneDelay);
  })();
</script>

<style>
  .intro-screen {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background:
      radial-gradient(circle at 50% 45%, rgba(255, 215, 150, 0.08), rgba(4, 4, 6, 0.8) 55%, rgba(0, 0, 0, 0.96) 100%),
      linear-gradient(180deg, #040405 0%, #090a0d 60%, #060607 100%);
    display: grid;
    place-items: center;
    color: #fbe7bb;
    overflow: hidden;
    text-align: center;
    padding: 20px;
    isolation: isolate;
  }

  .intro-screen::before,
  .intro-screen::after {
    content: '';
    position: absolute;
    inset: -20%;
    pointer-events: none;
  }

  .intro-screen::before {
    background:
      conic-gradient(from 190deg at 40% 45%, transparent, rgba(255, 220, 154, 0.12), transparent 33%),
      radial-gradient(ellipse at center, rgba(255, 210, 130, 0.14), transparent 64%);
    filter: blur(18px);
    animation: volumetricShift 4s ease-in-out infinite alternate;
  }

  .intro-screen::after {
    background:
      radial-gradient(circle at 16% 28%, rgba(255, 225, 168, 0.1), transparent 18%),
      radial-gradient(circle at 84% 38%, rgba(255, 214, 136, 0.09), transparent 22%);
    filter: blur(10px);
    opacity: 0.9;
  }

  .camera-rig {
    position: relative;
    z-index: 2;
    width: min(92vw, 940px);
    animation: dollyIn 3.6s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }

  .logo-wrap {
    position: relative;
    display: grid;
    place-items: center;
    gap: clamp(16px, 2.4vw, 22px);
    perspective: 1000px;
  }

  .pulse-backdrop {
    position: absolute;
    width: clamp(220px, 34vw, 420px);
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 210, 120, 0.4), rgba(255, 210, 120, 0.14) 38%, transparent 72%);
    filter: blur(5px);
    opacity: 0;
    animation: backPulse 3.4s ease-in-out 1.75s;
  }

  .monogram {
    position: relative;
    height: clamp(220px, 35vw, 380px);
    width: clamp(280px, 48vw, 520px);
    transform-style: preserve-3d;
    animation: finalDip 3.65s ease-in-out forwards;
  }

  .letter {
    position: absolute;
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    line-height: 0.82;
    color: #f5ca73;
    text-shadow:
      0 0 0 rgba(0, 0, 0, 0),
      0 0 18px rgba(255, 216, 140, 0.24),
      0 9px 25px rgba(0, 0, 0, 0.46);
    background: linear-gradient(160deg, #fff2ce 4%, #f0bf63 24%, #b6802c 52%, #f6d89d 82%, #8d5f1f 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: brightness(0.9) saturate(1.05);
    opacity: 0;
    transform: translateY(12px) scale(0.95);
  }

  .letter::before {
    content: '';
    position: absolute;
    inset: -18% -16%;
    background: radial-gradient(circle, rgba(255, 222, 155, 0.2), transparent 68%);
    filter: blur(12px);
    opacity: 0;
    pointer-events: none;
  }

  .letter-g {
    font-size: clamp(138px, 21vw, 245px);
    left: 4%;
    top: 0;
    animation: letterAppearG 0.9s cubic-bezier(0.2, 0.68, 0.18, 1) 0.18s forwards;
  }

  .letter-b {
    font-size: clamp(140px, 22vw, 252px);
    left: 31%;
    top: 22%;
    animation: letterAppearB 0.86s cubic-bezier(0.22, 0.67, 0.17, 1) 1.02s forwards;
  }

  .letter-p {
    font-size: clamp(140px, 22vw, 252px);
    left: 61%;
    top: 44%;
    animation: letterAppearP 0.92s cubic-bezier(0.24, 0.69, 0.18, 1) 1.86s forwards;
  }

  .sweep-line {
    position: absolute;
    top: 22%;
    left: 5%;
    width: 90%;
    height: 56%;
    background: linear-gradient(105deg, transparent 26%, rgba(255, 233, 183, 0.95) 48%, rgba(255, 227, 164, 0.35) 58%, transparent 72%);
    mix-blend-mode: screen;
    filter: blur(2px);
    opacity: 0;
    transform: translateX(-128%) skewX(-14deg);
    animation: logoSweep 0.92s ease-out 2.72s forwards;
    pointer-events: none;
  }

  .brand-subtitle {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-size: clamp(0.88rem, 1.8vw, 1.7rem);
    letter-spacing: clamp(0.22em, 0.7vw, 0.4em);
    color: #f0cc89;
    text-shadow: 0 2px 14px rgba(255, 208, 121, 0.28);
    opacity: 0;
    transform: translateY(14px);
    animation: subtitleReveal 0.85s ease 2.62s forwards;
  }

  .fog {
    position: absolute;
    width: 140%;
    height: 52%;
    left: -20%;
    filter: blur(30px);
    opacity: 0.3;
    pointer-events: none;
    z-index: 1;
  }

  .fog-a {
    top: -12%;
    background: radial-gradient(ellipse at 60% 45%, rgba(255, 220, 155, 0.14), rgba(10, 10, 12, 0.06) 40%, transparent 72%);
    animation: fogDriftA 4.1s ease-in-out infinite alternate;
  }

  .fog-b {
    bottom: -18%;
    background: radial-gradient(ellipse at 40% 55%, rgba(255, 203, 121, 0.12), rgba(10, 10, 12, 0.08) 40%, transparent 70%);
    animation: fogDriftB 4.2s ease-in-out infinite alternate;
  }

  .dust-field {
    position: absolute;
    inset: -10%;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  .dust-field span {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(255, 220, 150, 0.9);
    box-shadow: 0 0 10px rgba(255, 220, 150, 0.58);
    opacity: 0;
    animation: dustFloat 3.8s linear infinite;
  }

  .dust-field span:nth-child(1) { left: 12%; top: 68%; animation-delay: 0.1s; }
  .dust-field span:nth-child(2) { left: 30%; top: 32%; animation-delay: 0.78s; }
  .dust-field span:nth-child(3) { left: 48%; top: 58%; animation-delay: 1.45s; }
  .dust-field span:nth-child(4) { left: 65%; top: 36%; animation-delay: 0.5s; }
  .dust-field span:nth-child(5) { left: 78%; top: 66%; animation-delay: 1.9s; }
  .dust-field span:nth-child(6) { left: 90%; top: 24%; animation-delay: 1.2s; }

  .intro-hide {
    animation: fadeOutIntro 0.45s ease forwards;
  }

  @keyframes dollyIn {
    0% { transform: scale(0.89) translateY(9px); }
    100% { transform: scale(1) translateY(0); }
  }

  @keyframes volumetricShift {
    0% { transform: translateX(-2%) translateY(1%) scale(1); opacity: 0.9; }
    100% { transform: translateX(2%) translateY(-1%) scale(1.02); opacity: 1; }
  }

  @keyframes letterAppearG {
    0% { opacity: 0; transform: translateY(18px) scale(0.88); filter: blur(8px) brightness(0.7); }
    30% { opacity: 0.65; }
    70% { opacity: 1; transform: translateY(-2px) scale(1.03); }
    100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0) brightness(1.04); }
  }

  @keyframes letterAppearB {
    0% { opacity: 0; transform: translate3d(0, 18px, -45px) scale(0.9); filter: blur(8px) brightness(0.7); }
    35% { opacity: 0.72; }
    74% { opacity: 1; transform: translate3d(0, -1px, 0) scale(1.03); }
    100% { opacity: 1; transform: translate3d(0, 0, 0) scale(1); filter: blur(0) brightness(1.04); }
  }

  @keyframes letterAppearP {
    0% { opacity: 0; transform: translate3d(0, 16px, -30px) rotate(-6deg) scale(0.9); filter: blur(7px) brightness(0.7); }
    38% { opacity: 0.75; }
    74% { opacity: 1; transform: translate3d(0, -2px, 0) rotate(2deg) scale(1.03); }
    100% { opacity: 1; transform: translate3d(0, 0, 0) rotate(0) scale(1); filter: blur(0) brightness(1.04); }
  }

  @keyframes backPulse {
    0% { opacity: 0; transform: scale(0.8); }
    30% { opacity: 0.85; transform: scale(1.06); }
    100% { opacity: 0.16; transform: scale(1.24); }
  }

  @keyframes logoSweep {
    0% { opacity: 0; transform: translateX(-128%) skewX(-14deg); }
    20% { opacity: 0.9; }
    100% { opacity: 0; transform: translateX(126%) skewX(-14deg); }
  }

  @keyframes subtitleReveal {
    0% { opacity: 0; transform: translateY(14px); letter-spacing: 0.5em; }
    100% { opacity: 1; transform: translateY(0); letter-spacing: clamp(0.22em, 0.7vw, 0.4em); }
  }

  @keyframes finalDip {
    0%, 72% { filter: brightness(1); opacity: 1; }
    78% { filter: brightness(0.25); opacity: 0.08; }
    84% { filter: brightness(1.45); opacity: 1; }
    100% { filter: brightness(1.06); opacity: 1; }
  }

  @keyframes fogDriftA {
    from { transform: translateX(-2.5%) translateY(0); opacity: 0.24; }
    to { transform: translateX(2.5%) translateY(-3%); opacity: 0.36; }
  }

  @keyframes fogDriftB {
    from { transform: translateX(2.2%) translateY(0); opacity: 0.21; }
    to { transform: translateX(-2.2%) translateY(2.4%); opacity: 0.34; }
  }

  @keyframes dustFloat {
    0% { opacity: 0; transform: translate3d(0, 20px, 0) scale(0.8); }
    16% { opacity: 0.9; }
    100% { opacity: 0; transform: translate3d(-16px, -42px, 0) scale(1.35); }
  }

  @keyframes fadeOutIntro {
    to {
      opacity: 0;
      visibility: hidden;
    }
  }

  @media (max-width: 600px) {
    .camera-rig {
      width: min(96vw, 520px);
    }

    .monogram {
      height: clamp(190px, 54vw, 260px);
      width: min(94vw, 360px);
    }

    .brand-subtitle {
      max-width: 95%;
      line-height: 1.35;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .camera-rig,
    .pulse-backdrop,
    .monogram,
    .letter,
    .sweep-line,
    .brand-subtitle,
    .fog,
    .dust-field span,
    .intro-screen::before {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition: none !important;
    }

    .letter,
    .brand-subtitle {
      opacity: 1;
      transform: none;
    }
  }
  }
</style>

---
---

<div class="header-wrapper">
  <header>
    <a href="#" aria-label="Home link" class="logo-link">
      <img
        src="/images/GBP_OFFICIAL_LOGO.png"
        alt="GBP Home Art & Decors Logo"
        width="45"
        height="45"
        loading="eager"
        decoding="async"
      />
      <span class="header-name">GBP Home Art & Decors</span>
    </a>

    <div class="header-actions">
      <button id="theme-toggle" type="button" class="theme-toggle" aria-label="Toggle dark mode" aria-pressed="false">
        <span class="toggle-icon" aria-hidden="true">
          <span class="icon-sun">☀️</span>
          <span class="icon-moon">🌙</span>
        </span>
        <span class="toggle-label">Day</span>
      </button>

      <button id="scroll-top-button" type="button" class="scroll-top-button" aria-label="Scroll back to top">
        ↑ Top
      </button>
    </div>
  </header>
</div>

<script>
  const headerName = document.querySelector(".header-name");
  const scrollTopButton = document.getElementById("scroll-top-button");
  const themeToggle = document.getElementById("theme-toggle");
  const themeLabel = themeToggle?.querySelector(".toggle-label");
  const storageKey = "gbp-theme";
  const root = document.documentElement;
  const body = document.body;

  const handleScroll = () => {
    const heroSection = document.querySelector(".hero");
    const heroBottom = heroSection?.getBoundingClientRect().bottom ?? 0;

    if (headerName) {
      if (heroBottom < 100) {
        headerName.classList.add("visible");
      } else {
        headerName.classList.remove("visible");
      }
    }

    if (scrollTopButton) {
      if (heroBottom < 0) {
        scrollTopButton.classList.add("visible");
      } else {
        scrollTopButton.classList.remove("visible");
      }
    }
  };

  const updateActiveNav = () => {
    const navItems = document.querySelectorAll<HTMLAnchorElement>("#hero-nav ul li a");
    const sections = document.querySelectorAll<HTMLElement>("section[id]");
    let currentId = "";

    const atBottom = (window.innerHeight + window.scrollY) >= (document.body.scrollHeight - 50);
    if (atBottom && sections.length > 0) {
      currentId = sections[sections.length - 1].id;
    } else if (window.scrollY < 100) {
      currentId = "";
    } else {
      let bestOverlap = 0;
      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        const viewportHeight = window.innerHeight;
        const top = Math.max(0, rect.top);
        const bottom = Math.min(viewportHeight, rect.bottom);
        const overlap = Math.max(0, bottom - top);

        if (overlap > bestOverlap) {
          bestOverlap = overlap;
          currentId = section.id;
        }
      });
    }

    navItems.forEach((item) => {
      const href = item.getAttribute("href") || "";
      const sectionId = href.replace(/^#/, "");

      if (currentId === "" && href === "#") {
        item.classList.add("active");
      } else if (sectionId && sectionId === currentId) {
        item.classList.add("active");
      } else {
        item.classList.remove("active");
      }
    });
  };

  const applyTheme = (theme: string) => {
    const isDark = theme === "dark";
    root.setAttribute("data-theme", theme);
    body.classList.toggle("dark-mode", isDark);
    body.classList.toggle("light-mode", !isDark);

    if (themeToggle) {
      themeToggle.classList.toggle("active", isDark);
      themeToggle.setAttribute("aria-pressed", String(isDark));
      if (themeLabel) themeLabel.textContent = isDark ? "Night" : "Day";
    }

    localStorage.setItem(storageKey, theme);
  };

  const getPreferredTheme = () => {
    const storedTheme = localStorage.getItem(storageKey);
    if (storedTheme === "dark" || storedTheme === "light") {
      return storedTheme;
    }
    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  };

  document.addEventListener("DOMContentLoaded", () => {
    applyTheme(getPreferredTheme());

    themeToggle?.addEventListener("click", () => {
      const nextTheme = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
      applyTheme(nextTheme);
    });

    if (scrollTopButton) {
      scrollTopButton.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    }

    window.addEventListener("scroll", handleScroll, { passive: true });
    window.addEventListener("scroll", updateActiveNav, { passive: true });
    handleScroll();
    updateActiveNav();
  });
</script>

<style>
  .header-wrapper {
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    background: linear-gradient(135deg, rgba(17, 29, 122, 0.96), rgba(7, 14, 62, 0.95));
    backdrop-filter: blur(18px);
    box-shadow: 0 12px 30px rgba(4, 10, 34, 0.16);
    animation: slideIn 0.6s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 20px;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    min-width: 0;
  }

  .logo-link img {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    object-fit: contain;
    transition: 0.3s ease;
    box-shadow: 0 6px 16px rgba(255, 255, 255, 0.16);
  }

  .logo-link img:hover {
    transform: rotate(6deg) scale(1.08);
  }

  .header-name {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 600;
    color: #F3D79A;
    white-space: nowrap;
    overflow: hidden;
    max-width: 0;
    opacity: 0;
    transition: max-width 0.3s ease, opacity 0.3s ease;
  }

  .header-name:global(.visible) {
    max-width: 250px;
    opacity: 1;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }

  .theme-toggle {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: #ffffff;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.08));
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.16);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background 0.3s ease;
  }

  .theme-toggle::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.28) 40%, transparent 80%);
    transform: translateX(-120%);
    transition: transform 0.75s ease;
  }

  .theme-toggle:hover::before,
  .theme-toggle:focus-visible::before {
    transform: translateX(120%);
  }

  .theme-toggle:hover,
  .theme-toggle:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
    border-color: rgba(255, 255, 255, 0.4);
    outline: none;
  }

  .theme-toggle.active {
    background: linear-gradient(135deg, rgba(255, 233, 178, 0.25), rgba(255, 255, 255, 0.12));
    border-color: rgba(255, 233, 178, 0.45);
  }

  .toggle-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    font-size: 16px;
    transition: transform 0.3s ease;
  }

  .toggle-icon .icon-sun,
  .toggle-icon .icon-moon {
    position: absolute;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.35s ease, opacity 0.3s ease;
  }

  .toggle-icon .icon-sun {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .toggle-icon .icon-moon {
    opacity: 0;
    transform: rotate(-35deg) scale(0.6);
  }

  .theme-toggle.active .toggle-icon {
    transform: rotate(10deg);
  }

  .theme-toggle.active .toggle-icon .icon-sun {
    opacity: 0;
    transform: rotate(70deg) scale(0.6);
  }

  .theme-toggle.active .toggle-icon .icon-moon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .theme-toggle:hover .toggle-icon {
    transform: rotate(16deg) scale(1.08);
  }

  .toggle-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .scroll-top-button {
    border: none;
    border-radius: 999px;
    background: linear-gradient(135deg, #f3d79a, #d4a64f);
    color: #10235e;
    font-weight: 700;
    padding: 10px 16px;
    cursor: pointer;
    opacity: 0;
    transform: translateY(4px);
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 10px 24px rgba(17, 29, 122, 0.2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 42px;
  }

  .scroll-top-button.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .scroll-top-button:hover,
  .scroll-top-button:focus-visible {
    box-shadow: 0 14px 32px rgba(17, 29, 122, 0.24);
    outline: none;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    header {
      padding: 12px 16px;
    }

    .scroll-top-button {
      padding: 10px 14px;
      height: 40px;
    }
  }

  @media (max-width: 500px) {
    .header-name {
      display: none;
    }

    .theme-toggle {
      padding: 9px 10px;
    }

    .toggle-label {
      display: none;
    }

    .scroll-top-button {
      padding: 9px 12px;
      height: 38px;
    }
  }
</style>

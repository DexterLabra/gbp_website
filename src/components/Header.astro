---
---

<div class="header-wrapper">
  <header>
    <a href="#" aria-label="Home link" class="logo-link">
      <img
        src="/images/GBP_OFFICIAL_LOGO.png"
        alt="GBP Home Art & Decors Logo"
        width="45"
        height="45"
        loading="eager"
        decoding="async"
      />
    </a>

    <div class="header-notice" aria-label="Cash on delivery available nationwide">
      <span class="header-notice-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 12v7a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-7" />
          <path d="M21 7H3v5h18V7Z" />
          <path d="M12 20V7" />
          <path d="M12 7H7.8a2.3 2.3 0 1 1 0-4.6c2.7 0 4.2 4.6 4.2 4.6Z" />
          <path d="M12 7h4.2a2.3 2.3 0 1 0 0-4.6C13.5 2.4 12 7 12 7Z" />
        </svg>
      </span>
      <span class="header-notice-text">Cash on delivery available nationwide</span>
    </div>

    <div class="header-actions">
      <button id="theme-toggle" type="button" class="theme-toggle" aria-label="Toggle dark mode" aria-pressed="false">
        <span class="toggle-icon" aria-hidden="true">
          <span class="icon-sun">☀️</span>
          <span class="icon-moon">🌙</span>
        </span>
        <span class="toggle-label">Day</span>
      </button>
    </div>
  </header>
</div>

<script>
  const themeToggle = document.getElementById("theme-toggle");
  const themeLabel = themeToggle?.querySelector(".toggle-label");
  const storageKey = "gbp-theme";
  const root = document.documentElement;
  const body = document.body;

  const updateActiveNav = () => {
    const navItems = document.querySelectorAll<HTMLAnchorElement>("#hero-nav ul li a");
    const sections = document.querySelectorAll<HTMLElement>("section[id]");
    let currentId = "";

    const atBottom = (window.innerHeight + window.scrollY) >= (document.body.scrollHeight - 50);
    if (atBottom && sections.length > 0) {
      currentId = sections[sections.length - 1].id;
    } else if (window.scrollY < 100) {
      currentId = "";
    } else {
      let bestOverlap = 0;
      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        const viewportHeight = window.innerHeight;
        const top = Math.max(0, rect.top);
        const bottom = Math.min(viewportHeight, rect.bottom);
        const overlap = Math.max(0, bottom - top);

        if (overlap > bestOverlap) {
          bestOverlap = overlap;
          currentId = section.id;
        }
      });
    }

    navItems.forEach((item) => {
      const href = item.getAttribute("href") || "";
      const sectionId = href.replace(/^#/, "");

      if (currentId === "" && href === "#") {
        item.classList.add("active");
      } else if (sectionId && sectionId === currentId) {
        item.classList.add("active");
      } else {
        item.classList.remove("active");
      }
    });
  };

  const applyTheme = (theme: string) => {
    const isDark = theme === "dark";
    root.setAttribute("data-theme", theme);
    body.classList.toggle("dark-mode", isDark);
    body.classList.toggle("light-mode", !isDark);

    if (themeToggle) {
      themeToggle.classList.toggle("active", isDark);
      themeToggle.setAttribute("aria-pressed", String(isDark));
      if (themeLabel) themeLabel.textContent = isDark ? "Night" : "Day";
    }

    localStorage.setItem(storageKey, theme);
  };

  const getPreferredTheme = () => {
    const storedTheme = localStorage.getItem(storageKey);
    if (storedTheme === "dark" || storedTheme === "light") {
      return storedTheme;
    }
    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  };

  document.addEventListener("DOMContentLoaded", () => {
    applyTheme(getPreferredTheme());

    themeToggle?.addEventListener("click", () => {
      const nextTheme = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
      applyTheme(nextTheme);
    });

    window.addEventListener("scroll", updateActiveNav, { passive: true });
    updateActiveNav();
  });
</script>

<style>
  .header-wrapper {
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    background: linear-gradient(135deg, rgba(17, 29, 122, 0.96), rgba(7, 14, 62, 0.95));
    backdrop-filter: blur(18px);
    box-shadow: 0 12px 30px rgba(4, 10, 34, 0.16);
    animation: slideIn 0.6s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  header {
    display: grid;
    align-items: center;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 18px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 20px;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    min-width: 0;
  }

  .logo-link img {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    object-fit: contain;
    transition: 0.3s ease;
    box-shadow: 0 6px 16px rgba(255, 255, 255, 0.16);
  }

  .logo-link img:hover {
    transform: rotate(6deg) scale(1.08);
  }

  .header-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .header-notice {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    justify-self: center;
    gap: 14px;
    min-height: 50px;
    width: min(100%, 560px);
    max-width: 100%;
    min-width: 0;
    padding: 13px 24px;
    overflow: visible;
    text-align: center;
    isolation: isolate;
  }

  .header-notice-icon,
  .header-notice-text {
    position: relative;
    z-index: 1;
  }

  .header-notice-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff4d1;
    animation: noticeIconFloat 2.8s ease-in-out infinite;
  }

  .header-notice-icon svg {
    width: 20px;
    height: 20px;
  }

  .header-notice-text {
    color: #fff8e9;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.3;
    white-space: normal;
    text-wrap: balance;
  }

  @keyframes noticeIconFloat {
    0%, 100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-3px);
    }
  }

  .theme-toggle {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: #ffffff;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.08));
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.16);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background 0.3s ease;
  }

  .theme-toggle::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.28) 40%, transparent 80%);
    transform: translateX(-120%);
    transition: transform 0.75s ease;
  }

  .theme-toggle:hover::before,
  .theme-toggle:focus-visible::before {
    transform: translateX(120%);
  }

  .theme-toggle:hover,
  .theme-toggle:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
    border-color: rgba(255, 255, 255, 0.4);
    outline: none;
  }

  .theme-toggle.active {
    background: linear-gradient(135deg, rgba(255, 233, 178, 0.25), rgba(255, 255, 255, 0.12));
    border-color: rgba(255, 233, 178, 0.45);
  }

  .toggle-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    font-size: 16px;
    transition: transform 0.3s ease;
  }

  .toggle-icon .icon-sun,
  .toggle-icon .icon-moon {
    position: absolute;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.35s ease, opacity 0.3s ease;
  }

  .toggle-icon .icon-sun {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .toggle-icon .icon-moon {
    opacity: 0;
    transform: rotate(-35deg) scale(0.6);
  }

  .theme-toggle.active .toggle-icon {
    transform: rotate(10deg);
  }

  .theme-toggle.active .toggle-icon .icon-sun {
    opacity: 0;
    transform: rotate(70deg) scale(0.6);
  }

  .theme-toggle.active .toggle-icon .icon-moon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .theme-toggle:hover .toggle-icon {
    transform: rotate(16deg) scale(1.08);
  }

  .toggle-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  @media (max-width: 768px) {
    header {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 12px;
      padding: 12px 16px;
    }

    .header-notice {
      width: 100%;
      max-width: 100%;
      min-height: 44px;
      padding: 10px 14px;
      gap: 10px;
    }

    .header-notice-text {
      font-size: 10px;
      letter-spacing: 0.035em;
      line-height: 1.2;
    }

    .header-notice-icon svg {
      width: 16px;
      height: 16px;
    }

    .theme-toggle {
      padding: 9px 11px;
    }
  }

  @media (max-width: 500px) {
    header {
      gap: 8px;
      padding: 10px 12px;
    }

    .logo-link img {
      width: 40px;
      height: 40px;
    }

    .header-notice {
      gap: 8px;
      padding: 8px 10px;
      min-height: 38px;
    }

    .header-notice-icon {
      width: auto;
      height: auto;
    }

    .header-notice-icon svg {
      width: 14px;
      height: 14px;
    }

    .header-notice-text {
      font-size: 9px;
      letter-spacing: 0.02em;
    }

    .theme-toggle {
      padding: 8px 10px;
    }

    .toggle-label {
      display: none;
    }
  }
</style>

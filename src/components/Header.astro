---
---

<div class="header-wrapper">
  <header>
    <a href="#" aria-label="Home link" class="logo-link">
      <img
        src="/images/GBP LOGO.png"
        alt="GBP Home Art & Decors Logo"
        width="45"
        height="45"
        loading="eager"
        decoding="async"
      />
      <span class="header-name">GBP Home Art & Decors</span>
    </a>

    <button id="scroll-top-button" type="button" class="scroll-top-button" aria-label="Scroll back to top">
      ↑ Top
    </button>
  </header>
</div>

<script>
  const headerName = document.querySelector(".header-name");
  const scrollTopButton = document.getElementById("scroll-top-button");

  const handleScroll = () => {
    const heroSection = document.querySelector(".hero");
    const heroBottom = heroSection?.getBoundingClientRect().bottom ?? 0;

    if (headerName) {
      if (heroBottom < 100) {
        headerName.classList.add("visible");
      } else {
        headerName.classList.remove("visible");
      }
    }

    if (scrollTopButton) {
      if (heroBottom < 0) {
        scrollTopButton.classList.add("visible");
      } else {
        scrollTopButton.classList.remove("visible");
      }
    }
  };

  const updateActiveNav = () => {
    const navItems = document.querySelectorAll<HTMLAnchorElement>("#hero-nav ul li a");
    const sections = document.querySelectorAll<HTMLElement>("section[id]");
    let currentId = "";

    const atBottom = (window.innerHeight + window.scrollY) >= (document.body.scrollHeight - 50);
    if (atBottom && sections.length > 0) {
      currentId = sections[sections.length - 1].id;
    } else if (window.scrollY < 100) {
      currentId = "";
    } else {
      let bestOverlap = 0;
      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        const viewportHeight = window.innerHeight;
        const top = Math.max(0, rect.top);
        const bottom = Math.min(viewportHeight, rect.bottom);
        const overlap = Math.max(0, bottom - top);

        if (overlap > bestOverlap) {
          bestOverlap = overlap;
          currentId = section.id;
        }
      });
    }

    navItems.forEach((item) => {
      const href = item.getAttribute("href") || "";
      const sectionId = href.replace(/^#/, "");

      if (currentId === "" && href === "#") {
        item.classList.add("active");
      } else if (sectionId && sectionId === currentId) {
        item.classList.add("active");
      } else {
        item.classList.remove("active");
      }
    });
  };

  document.addEventListener("DOMContentLoaded", () => {
    if (scrollTopButton) {
      scrollTopButton.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    }

    window.addEventListener("scroll", handleScroll, { passive: true });
    window.addEventListener("scroll", updateActiveNav, { passive: true });
    handleScroll();
    updateActiveNav();
  });
</script>

<style>
  .header-wrapper {
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    background: rgba(17, 29, 122, 0.92);
    backdrop-filter: blur(18px);
    animation: slideIn 0.6s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 20px;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .logo-link img {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    object-fit: contain;
    transition: 0.3s;
  }

  .logo-link img:hover {
    transform: rotate(6deg) scale(1.08);
  }

  .header-name {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 600;
    color: #D4A64F;
    white-space: nowrap;
    overflow: hidden;
    max-width: 0;
    opacity: 0;
    transition: max-width 0.3s ease, opacity 0.3s ease;
  }

  .header-name:global(.visible) {
    max-width: 250px;
    opacity: 1;
  }

  .scroll-top-button {
    margin-left: auto;
    border: none;
    border-radius: 999px;
    background: rgba(212, 166, 79, 0.95);
    color: #10235e;
    font-weight: 700;
    padding: 11px 18px;
    cursor: pointer;
    opacity: 0;
    transform: translateY(4px);
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 8px 24px rgba(17, 29, 122, 0.12);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
  }

  .scroll-top-button.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .scroll-top-button:hover,
  .scroll-top-button:focus-visible {
    box-shadow: 0 14px 32px rgba(17, 29, 122, 0.2);
    outline: none;
  }

  @media (max-width: 768px) {
    .scroll-top-button {
      padding: 10px 16px;
      height: 40px;
    }
  }

  @media (max-width: 500px) {
    .scroll-top-button {
      padding: 10px 14px;
      height: 38px;
    }
  }
</style>

---
---

<section class="inquiry-section" id="inquiry">
  <h2 class="section-title">SEND US AN INQUIRY</h2>

  <form
    id="inquiry-form"
    action="https://api.web3forms.com/submit"
    method="POST"
    class="inquiry-form"
  >
    <input type="hidden" name="access_key" value="9fad7df4-ee5c-4329-b634-5c51136ea9d1" />

    <div class="form-row">
      <div class="form-group">
        <label for="first-name">First Name</label>
        <input
          type="text"
          id="first-name"
          name="first_name"
          placeholder="Enter your first name"
          required
        />
      </div>
      <div class="form-group">
        <label for="last-name">Last Name</label>
        <input
          type="text"
          id="last-name"
          name="last_name"
          placeholder="Enter your last name"
          required
        />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="email">Email Address</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="e.g name@example.com"
          required
        />
      </div>
      <div class="form-group">
        <label for="mobile">Mobile Number</label>
        <input
          type="tel"
          id="mobile"
          name="mobile_number"
          placeholder="+63 9XX XXX XXXX"
          required
        />
      </div>
    </div>

    <div class="form-group full-width message-block">
      <label for="message">Message</label>
      <textarea
        id="message"
        name="message"
        rows="5"
        placeholder="How can we help you?"
        required
      ></textarea>

      <div class="consent-card" aria-live="polite">
        <p class="consent-copy">
          By submitting this inquiry, you confirm that the information you provide is accurate and that you agree to our Privacy Policy and Terms of Use. We will use your details only to respond to your request and provide the support you need.
        </p>
        <label class="consent-checkbox" for="privacy-terms">
          <input type="checkbox" id="privacy-terms" name="privacy_terms" required />
          <span class="checkbox-mark" aria-hidden="true"></span>
          <span>I agree to the Privacy Policy and Terms of Use.</span>
        </label>
      </div>
    </div>

    <button type="submit" class="submit-btn">
      <span class="btn-text">Submit</span>
      <span class="btn-loading" aria-hidden="true">Sending...</span>
    </button>

    <p class="form-status" id="form-status" aria-live="polite"></p>
  </form>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('inquiry-form') as HTMLFormElement;
    const status = document.getElementById('form-status') as HTMLParagraphElement;
    const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
    const privacyCheckbox = form.querySelector('#privacy-terms') as HTMLInputElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const isValid = form.reportValidity();
      const isAccepted = privacyCheckbox.checked;

      if (!isValid || !isAccepted) {
        status.textContent = 'Please complete all fields and agree to the Privacy Policy and Terms of Use.';
        status.className = 'form-status error';
        return;
      }

      submitBtn.disabled = true;
      submitBtn.classList.add('loading');
      status.textContent = '';
      status.className = 'form-status';

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: new FormData(form),
        });

        const data = await response.json();

        if (data.success) {
          status.textContent = 'Thank you! Your inquiry has been sent successfully.';
          status.classList.add('success');
          form.reset();
          privacyCheckbox.checked = false;
        } else {
          status.textContent = 'Something went wrong. Please try again.';
          status.classList.add('error');
        }
      } catch {
        status.textContent = 'Network error. Please check your connection and try again.';
        status.classList.add('error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.classList.remove('loading');
      }
    });
  });
</script>

<style>
  .inquiry-section {
    padding: 120px 5%;
    background:
      radial-gradient(circle at top left, rgba(212, 166, 79, 0.22), transparent 26%),
      radial-gradient(circle at bottom right, rgba(17, 29, 122, 0.16), transparent 24%),
      linear-gradient(135deg, var(--surface-strong) 0%, var(--surface-alt) 42%, var(--page-bg) 100%);
    color: var(--page-text);
    position: relative;
    overflow: hidden;
    transition: background-color 0.4s ease, color 0.4s ease;
  }

  .inquiry-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, rgba(255, 255, 255, 0.22), transparent 35%, rgba(17, 29, 122, 0.06));
    pointer-events: none;
  }

  .section-title {
    position: relative;
    z-index: 1;
    text-align: center;
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 3.4vw, 2.8rem);
    margin: 0 0 42px;
    color: var(--heading-color);
    letter-spacing: 0.03em;
    font-weight: 700;
    text-shadow: 0 1px 0 rgba(255,255,255,0.18);
  }

  .section-title::after {
    content: '';
    display: block;
    width: 130px;
    height: 4px;
    margin: 15px auto 0;
    background: linear-gradient(to right, #d4a64f, #ffd66b, #10235e);
    border-radius: 999px;
  }

  .inquiry-form {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 40px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 32px;
    box-shadow: 0 26px 70px var(--glass-shadow);
    backdrop-filter: blur(20px);
    position: relative;
    z-index: 1;
    transition: background-color 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group.full-width {
    grid-column: 1 / -1;
  }

  .message-block {
    gap: 12px;
  }

  .consent-card {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: 14px 16px;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.08));
    border: 1px solid rgba(212, 166, 79, 0.22);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18), 0 12px 28px rgba(16, 35, 94, 0.1);
    backdrop-filter: blur(10px);
    animation: consentReveal 0.45s ease;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  }

  .consent-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(120deg, rgba(212, 166, 79, 0.6), rgba(255, 255, 255, 0.18), rgba(16, 35, 94, 0.28));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .consent-card::after {
    content: '';
    position: absolute;
    inset: 10px 16px auto 16px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.85), transparent);
    opacity: 0.65;
    pointer-events: none;
  }

  .consent-copy {
    font-size: 13px;
    line-height: 1.7;
    color: var(--muted-text);
    margin-bottom: 10px;
    position: relative;
    z-index: 1;
  }

  .consent-checkbox {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    font-weight: 600;
    color: var(--page-text);
    cursor: pointer;
    user-select: none;
    line-height: 1.55;
  }

  .consent-checkbox input[type='checkbox'] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .checkbox-mark {
    position: relative;
    width: 20px;
    height: 20px;
    border-radius: 7px;
    border: 1.5px solid rgba(212, 166, 79, 0.7);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
    background: rgba(255, 255, 255, 0.14);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
    transition: transform 0.2s ease, background-color 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .checkbox-mark::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 10px;
    background: radial-gradient(circle, rgba(212, 166, 79, 0.25), transparent 70%);
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .checkbox-mark::after {
    content: '✓';
    color: var(--button-text);
    font-size: 12px;
    font-weight: 700;
    opacity: 0;
    transform: scale(0.7);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .consent-checkbox:hover .checkbox-mark {
    transform: translateY(-1px);
  }

  .consent-checkbox:hover .checkbox-mark::before,
  .consent-checkbox input[type='checkbox']:focus-visible + .checkbox-mark::before {
    opacity: 1;
    transform: scale(1);
    animation: checkboxPulse 1.8s ease-in-out infinite;
  }

  .consent-checkbox input[type='checkbox']:checked + .checkbox-mark {
    background: linear-gradient(135deg, rgba(212, 166, 79, 0.95), rgba(204, 154, 45, 0.88));
    border-color: rgba(132, 214, 139, 0.9);
    transform: scale(1.03);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18), 0 0 0 4px rgba(132, 214, 139, 0.16);
  }

  .consent-checkbox input[type='checkbox']:checked + .checkbox-mark::before {
    opacity: 1;
    transform: scale(1);
    animation: checkboxPulse 1.6s ease-in-out infinite;
    background: radial-gradient(circle, rgba(132, 214, 139, 0.24), transparent 72%);
  }

  .consent-checkbox input[type='checkbox']:checked + .checkbox-mark::after {
    opacity: 1;
    transform: scale(1);
  }

  .consent-card:has(.consent-checkbox input[type='checkbox']:checked) {
    border-color: rgba(132, 214, 139, 0.38);
    background: linear-gradient(135deg, rgba(132, 214, 139, 0.12), rgba(212, 166, 79, 0.08) 60%, rgba(255, 255, 255, 0.12));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22), 0 13px 28px rgba(132, 214, 139, 0.14);
  }

  .consent-card:has(.consent-checkbox input[type='checkbox']:checked) .consent-copy {
    color: var(--page-text);
  }

  @keyframes consentReveal {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes checkboxPulse {
    0%,
    100% {
      transform: scale(0.86);
      opacity: 0.35;
    }
    50% {
      transform: scale(1.08);
      opacity: 0.78;
    }
  }

  label {
    font-size: 13px;
    font-weight: 700;
    color: var(--heading-color);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  input,
  textarea {
    font-family: 'Poppins', sans-serif;
    font-size: 15px;
    padding: 16px 20px;
    border: 1.5px solid var(--border-color);
    border-radius: 16px;
    background: var(--input-bg);
    color: var(--input-text);
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease, background 0.25s ease;
    outline: none;
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.03);
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--input-placeholder);
  }

  input:focus,
  textarea:focus {
    border-color: var(--accent);
    background: var(--input-bg);
    box-shadow: 0 0 0 3px rgba(204, 154, 45, 0.16);
    transform: translateY(-1px);
  }

  textarea {
    resize: vertical;
    min-height: 120px;
  }

  .submit-btn {
    align-self: center;
    padding: 16px 48px;
    font-family: 'Poppins', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: #fffdf8;
    background: linear-gradient(135deg, #10235e 0%, #2746a6 55%, #d4a64f 100%);
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
    position: relative;
    overflow: hidden;
    margin-top: 10px;
    box-shadow: 0 16px 34px rgba(16, 35, 94, 0.18);
  }

  .submit-btn:hover:not(:disabled) {
    transform: translateY(-3px) scale(1.01);
    box-shadow: 0 20px 42px rgba(16, 35, 94, 0.24);
    filter: brightness(1.04);
  }

  .submit-btn:active:not(:disabled) {
    transform: translateY(0) scale(0.99);
  }

  .submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .btn-loading {
    display: none;
  }

  .submit-btn.loading .btn-text {
    display: none;
  }

  .submit-btn.loading .btn-loading {
    display: inline;
  }

  .form-status {
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    min-height: 20px;
    margin-top: 4px;
    color: var(--muted-text);
  }

  .form-status.success {
    color: #84d68b;
  }

  .form-status.error {
    color: #ff968b;
  }

  @media (max-width: 600px) {
    .inquiry-section {
      padding: 80px 5%;
    }

    .section-title {
      font-size: 32px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .consent-copy {
      font-size: 12px;
    }

    .consent-checkbox {
      font-size: 13px;
    }

    .submit-btn {
      width: 100%;
      padding: 16px 24px;
    }
  }
</style>

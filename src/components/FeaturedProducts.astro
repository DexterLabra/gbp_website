---
import { featuredProducts } from '../data/featured';
---

<section id="featured" class="featured-section">
  <h2 class="section-title">FEATURED PRODUCTS</h2>

  <div class="featured-container">
    <!-- Left: Large product image with name overlay -->
    <div class="featured-image-wrapper">
      <img
        id="featured-main-image"
        src={featuredProducts[0].image}
        alt={featuredProducts[0].name}
        class="featured-image"
        data-fit={featuredProducts[0].fit ?? 'contain'}
      />
      <span id="featured-image-name" class="featured-image-name">{featuredProducts[0].name}</span>
    </div>

    <!-- Right: Product info + carousel -->
    <div class="featured-details">
      <div class="featured-info">
        <span id="featured-category" class="featured-category">{featuredProducts[0].category}</span>
        <h3 id="featured-title" class="featured-title">{featuredProducts[0].name}</h3>
        <p id="featured-price" class="featured-price">{featuredProducts[0].price}</p>
      </div>

      <div class="carousel-wrapper">
        <button class="carousel-nav carousel-prev" aria-label="Previous items">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>

        <div class="featured-carousel">
          <div class="carousel-track">
            {featuredProducts.map((product, index) => (
              <button
                class={`carousel-item ${index === 0 ? 'active' : ''}`}
                data-index={index}
                data-name={product.name}
                data-category={product.category}
                data-price={product.price}
                data-image={product.image}
                data-fit={product.fit ?? 'contain'}
                aria-label={`View ${product.name}`}
              >
                <img
                  src={product.image}
                  alt={product.name}
                  class="carousel-thumb"
                  data-fit={product.fit ?? 'contain'}
                />
                <span class="carousel-item-name">{product.name}</span>
              </button>
            ))}
          </div>
        </div>

        <button class="carousel-nav carousel-next" aria-label="Next items">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.querySelector<HTMLDivElement>('.carousel-track')!;
    const carousel = document.querySelector<HTMLDivElement>('.featured-carousel')!;
    const carouselItems = document.querySelectorAll<HTMLButtonElement>('.carousel-item');
    const prevBtn = document.querySelector<HTMLButtonElement>('.carousel-prev')!;
    const nextBtn = document.querySelector<HTMLButtonElement>('.carousel-next')!;
    const imageWrapper = document.querySelector<HTMLDivElement>('.featured-image-wrapper')!;
    const mainImage = document.getElementById('featured-main-image') as HTMLImageElement;
    const imageName = document.getElementById('featured-image-name') as HTMLSpanElement;
    const title = document.getElementById('featured-title') as HTMLHeadingElement;
    const category = document.getElementById('featured-category') as HTMLSpanElement;
    const price = document.getElementById('featured-price') as HTMLParagraphElement;

    function getScrollStep() {
      const firstItem = carouselItems[0];
      if (!firstItem) return 132;

      const itemWidth = firstItem.offsetWidth;
      const trackStyles = window.getComputedStyle(track);
      const gap = Number.parseFloat(trackStyles.columnGap || trackStyles.gap || '0');

      return (itemWidth + gap) * 2;
    }

    function selectItem(item: HTMLButtonElement) {
      carouselItems.forEach((el) => el.classList.remove('active'));
      item.classList.add('active');
      imageWrapper.classList.remove('is-switching');
      void imageWrapper.offsetWidth;
      imageWrapper.classList.add('is-switching');

      const newImage = item.dataset.image || '';
      const newName = item.dataset.name || '';
      const newCategory = item.dataset.category || '';
      const newPrice = item.dataset.price || '';
      const newFit = item.dataset.fit || 'contain';

      mainImage.src = newImage;
      mainImage.alt = newName;
      mainImage.dataset.fit = newFit;
      imageName.textContent = newName;
      title.textContent = newName;
      category.textContent = newCategory;
      price.textContent = newPrice;

      window.setTimeout(() => {
        imageWrapper.classList.remove('is-switching');
      }, 950);
    }

    carouselItems.forEach((item) => {
      item.addEventListener('click', () => selectItem(item));
    });

    // Infinite scroll: when reaching the end, loop back
    prevBtn.addEventListener('click', () => {
      const scrollLeft = carousel.scrollLeft;
      const scrollStep = getScrollStep();
      if (scrollLeft <= 0) {
        // Jump to end
        carousel.scrollTo({ left: carousel.scrollWidth, behavior: 'smooth' });
      } else {
        carousel.scrollBy({ left: -scrollStep, behavior: 'smooth' });
      }
    });

    nextBtn.addEventListener('click', () => {
      const maxScroll = carousel.scrollWidth - carousel.clientWidth;
      const scrollStep = getScrollStep();
      if (carousel.scrollLeft >= maxScroll - 2) {
        // Loop back to start
        carousel.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        carousel.scrollBy({ left: scrollStep, behavior: 'smooth' });
      }
    });
  });
</script>

<style>
  @property --featured-border-angle {
    syntax: '<angle>';
    inherits: false;
    initial-value: 0deg;
  }

  .featured-section {
    padding: 80px 5% 100px;
    background: var(--surface-strong);
    color: var(--page-text);
    transition: background-color 0.4s ease, color 0.4s ease;
  }

  .section-title {
    text-align: center;
    font-family: 'Playfair Display', serif;
    font-size: 45px;
    margin: 0 0 50px;
    color: var(--heading-color);
  }

  .section-title::after {
    content: '';
    display: block;
    width: 120px;
    height: 3px;
    margin: 15px auto 0;
    background: linear-gradient(to right, #D4A64F, #FFD978, #D4A64F);
  }

  .featured-container {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: center;
  }

  /* Left side: image with overlay name */
  .featured-image-wrapper {
    --featured-hero-border-angle: 0deg;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: var(--glass-bg);
    border: 1px solid rgba(212, 166, 79, 0.18);
    box-shadow: 0 22px 50px var(--glass-shadow), 0 0 30px rgba(212, 166, 79, 0.14);
    backdrop-filter: blur(18px);
    isolation: isolate;
    transition: background-color 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease, transform 0.4s ease;
  }

  .featured-image-wrapper::before,
  .featured-image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
  }

  .featured-image-wrapper::before {
    inset: -1px;
    padding: 1.5px;
    background: conic-gradient(
      from var(--featured-hero-border-angle),
      rgba(212, 166, 79, 0),
      rgba(255, 234, 170, 0.96),
      rgba(212, 166, 79, 0.42),
      rgba(255, 247, 218, 1),
      rgba(212, 166, 79, 0)
    );
    opacity: 0.82;
    animation: featuredHeroBorderSpin 7s linear infinite;
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    mask-composite: exclude;
  }

  .featured-image-wrapper::after {
    inset: 1px;
    border-radius: calc(16px - 1px);
    background:
      radial-gradient(circle at 14% 16%, rgba(255, 239, 190, 0.24), transparent 24%),
      radial-gradient(circle at 88% 18%, rgba(212, 166, 79, 0.16), transparent 20%),
      radial-gradient(circle at 84% 82%, rgba(212, 166, 79, 0.18), transparent 24%);
    opacity: 0.85;
    z-index: 0;
  }

  .featured-image-wrapper:hover {
    transform: translateY(-4px);
    box-shadow: 0 28px 58px rgba(7, 17, 31, 0.22), 0 0 38px rgba(212, 166, 79, 0.22);
  }

  .featured-image-wrapper.is-switching::before {
    animation: featuredHeroBorderSpin 1.1s linear infinite, featuredHeroBorderPulse 0.95s ease;
  }

  .featured-image-wrapper.is-switching::after {
    animation: featuredHeroSparkle 0.95s ease;
  }

  .featured-image {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    transition: opacity 0.3s ease, transform 0.7s ease, filter 0.5s ease;
    background: var(--surface-alt);
    padding: 14px;
  }

  .featured-image-wrapper:hover .featured-image {
    transform: scale(1.02);
    filter: drop-shadow(0 14px 24px rgba(212, 166, 79, 0.16));
  }

  .featured-image-wrapper.is-switching .featured-image {
    animation: featuredHeroImageSwap 0.95s ease;
  }

  .featured-image[data-fit='contain'] {
    object-fit: contain;
  }

  .featured-image-name {
    position: absolute;
    z-index: 1;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 24px;
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
  }

  /* Right side: info + carousel */
  .featured-details {
    display: flex;
    flex-direction: column;
    gap: 32px;
    min-width: 0;
  }

  .featured-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .featured-category {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--accent);
  }

  .featured-title {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    color: var(--heading-color);
    margin: 0;
    line-height: 1.3;
  }

  .featured-price {
    font-size: 22px;
    font-weight: 700;
    color: var(--page-text);
    margin: 4px 0 0;
  }

  /* Carousel wrapper with nav buttons */
  .carousel-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }

  .carousel-nav {
    flex: 0 0 auto;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid var(--border-color);
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--page-text);
    transition: border-color 0.2s, background 0.2s, color 0.2s, box-shadow 0.2s ease;
    box-shadow: 0 8px 18px var(--shadow-color);
  }

  .carousel-nav:hover {
    border-color: var(--accent);
    background: rgba(212, 166, 79, 0.08);
    color: var(--accent);
  }

  /* Carousel scroll area */
  .featured-carousel {
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    overflow-y: visible;
    scrollbar-width: none;
  }

  .featured-carousel::-webkit-scrollbar {
    display: none;
  }

  .carousel-track {
    display: flex;
    gap: 12px;
    padding: 6px 4px;
  }

  .carousel-item {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    flex: 0 0 auto;
    width: clamp(108px, 17vw, 132px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 9px;
    border: 1px solid rgba(212, 166, 79, 0.16);
    border-radius: 16px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(212, 166, 79, 0.04)),
      var(--surface);
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.25s ease, border-color 0.25s ease;
    box-shadow: 0 12px 28px var(--shadow-color);
  }

  .carousel-item::before,
  .carousel-item::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.4s ease;
  }

  .carousel-item::before {
    inset: -1px;
    padding: 1px;
    background: conic-gradient(
      from var(--featured-border-angle),
      rgba(212, 166, 79, 0),
      rgba(255, 232, 162, 0.95),
      rgba(212, 166, 79, 0.45),
      rgba(255, 247, 218, 1),
      rgba(212, 166, 79, 0)
    );
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: exclude;
  }

  .carousel-item::after {
    inset: -28%;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 240, 183, 0.7), transparent 34%),
      radial-gradient(circle at 80% 82%, rgba(212, 166, 79, 0.28), transparent 40%),
      linear-gradient(120deg, transparent 24%, rgba(255, 245, 210, 0.45) 50%, transparent 76%);
    transform: translateX(-18%) scale(0.92);
    mix-blend-mode: screen;
  }

  .carousel-item:hover,
  .carousel-item:focus-visible {
    border-color: rgba(255, 232, 162, 0.42);
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 18px 34px rgba(6, 16, 44, 0.22), 0 0 28px rgba(212, 166, 79, 0.34);
  }

  .carousel-item:hover::before,
  .carousel-item:hover::after,
  .carousel-item:focus-visible::before,
  .carousel-item:focus-visible::after,
  .carousel-item.active::before,
  .carousel-item.active::after {
    opacity: 1;
  }

  .carousel-item:hover::before,
  .carousel-item:focus-visible::before,
  .carousel-item.active::before {
    animation: featuredBorderSpin 2.8s linear infinite;
  }

  .carousel-item:hover::after,
  .carousel-item:focus-visible::after,
  .carousel-item.active::after {
    transform: translateX(0) scale(1);
    animation: featuredShineSweep 2.2s ease-in-out infinite alternate;
  }

  .carousel-item.active {
    border-color: rgba(255, 232, 162, 0.44);
    box-shadow: 0 14px 30px rgba(6, 16, 44, 0.2), 0 0 32px rgba(212, 166, 79, 0.28);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(212, 166, 79, 0.1)),
      var(--surface);
  }

  .carousel-thumb {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    object-position: center;
    border-radius: 10px;
    background: var(--surface-alt);
    padding: 6px;
    transition: transform 0.35s ease, filter 0.35s ease;
  }

  .carousel-thumb[data-fit='contain'] {
    object-fit: contain;
  }

  .carousel-item:hover .carousel-thumb,
  .carousel-item:focus-visible .carousel-thumb,
  .carousel-item.active .carousel-thumb {
    transform: scale(1.03);
    filter: drop-shadow(0 10px 18px rgba(212, 166, 79, 0.22));
  }

  .carousel-item-name {
    position: relative;
    z-index: 1;
    font-size: clamp(10px, 0.9vw, 11px);
    font-weight: 600;
    color: var(--muted-text);
    text-align: center;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @keyframes featuredBorderSpin {
    to {
      --featured-border-angle: 360deg;
    }
  }

  @keyframes featuredHeroBorderSpin {
    to {
      --featured-hero-border-angle: 360deg;
    }
  }

  @keyframes featuredHeroBorderPulse {
    0% {
      opacity: 0.82;
      filter: drop-shadow(0 0 0 rgba(255, 225, 145, 0));
    }

    40% {
      opacity: 1;
      filter: drop-shadow(0 0 18px rgba(255, 225, 145, 0.48));
    }

    100% {
      opacity: 0.82;
      filter: drop-shadow(0 0 0 rgba(255, 225, 145, 0));
    }
  }

  @keyframes featuredHeroSparkle {
    0% {
      opacity: 0.45;
      transform: scale(0.98);
      filter: brightness(1);
    }

    50% {
      opacity: 1;
      transform: scale(1.015);
      filter: brightness(1.18);
    }

    100% {
      opacity: 0.85;
      transform: scale(1);
      filter: brightness(1);
    }
  }

  @keyframes featuredHeroImageSwap {
    0% {
      opacity: 0.78;
      transform: scale(0.985);
      filter: brightness(0.96) saturate(0.98);
    }

    45% {
      opacity: 1;
      transform: scale(1.025);
      filter: brightness(1.08) saturate(1.04);
    }

    100% {
      opacity: 1;
      transform: scale(1);
      filter: brightness(1) saturate(1);
    }
  }

  @keyframes featuredShineSweep {
    from {
      transform: translate3d(-14%, 0, 0) scale(0.96);
      filter: brightness(0.95);
    }

    to {
      transform: translate3d(12%, -2%, 0) scale(1.04);
      filter: brightness(1.08);
    }
  }

  /* Tablet: stack to single column */
  @media (max-width: 1024px) {
    .featured-container {
      grid-template-columns: 1fr;
      gap: 28px;
      max-width: 700px;
      margin: 0 auto;
    }

    .featured-image-wrapper {
      aspect-ratio: 4 / 3;
    }

    .featured-image[data-fit='contain'] {
      padding: 16px;
    }

    .featured-title {
      font-size: 24px;
    }

    .featured-price {
      font-size: 20px;
    }
  }

  /* Mobile */
  @media (max-width: 600px) {
    .featured-section {
      padding: 56px 4% 72px;
    }

    .section-title {
      font-size: 32px;
      margin-bottom: 36px;
    }

    .featured-container {
      max-width: 100%;
      gap: 18px;
    }

    .featured-image-wrapper {
      aspect-ratio: 4 / 3;
      border-radius: 12px;
    }

    .featured-image-wrapper::after {
      border-radius: calc(12px - 1px);
    }

    .featured-image[data-fit='contain'] {
      padding: 12px;
    }

    .featured-image-name {
      font-size: 16px;
      padding: 16px 18px;
    }

    .featured-title {
      font-size: 20px;
      line-height: 1.2;
    }

    .featured-price {
      font-size: 18px;
    }

    .featured-details {
      gap: 22px;
    }

    .carousel-wrapper {
      gap: 6px;
      align-items: stretch;
    }

    .featured-carousel {
      overflow-x: auto;
      scroll-snap-type: x proximity;
      padding-bottom: 4px;
    }

    .carousel-track {
      gap: 10px;
      padding: 4px 2px 6px;
    }

    .carousel-item {
      width: min(31vw, 112px);
      min-width: 96px;
      padding: 8px;
      scroll-snap-align: start;
    }

    .carousel-item-name {
      font-size: 10px;
    }

    .carousel-nav {
      width: 30px;
      height: 30px;
      align-self: center;
      box-shadow: 0 6px 16px var(--shadow-color);
    }
  }

  @media (hover: none) {
    .featured-image-wrapper:hover {
      transform: none;
    }

    .carousel-item:hover {
      transform: none;
    }

    .carousel-item:hover::before,
    .carousel-item:hover::after {
      opacity: 0;
    }
  }
</style>

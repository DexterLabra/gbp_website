---
const navLinks = [
  { href: "#", text: "Home" },
  { href: "#featured", text: "Featured Products" },
  { href: "#collections", text: "Collections" },
  { href: "#testimonials", text: "Client Feedback" },
  { href: "#shipping", text: "Shipping" },
  { href: "#inquiry", text: "Inquire" },
  { href: "#contact", text: "Contact" },
];
---

<section class="hero" id="hero">
  <div class="hero-content">
    <div class="hero-brand">
      <img
        src="/images/GBP_OFFICIAL_LOGO.png"
        alt="GBP Home Art & Decors official logo"
        class="hero-logo"
        width="240"
        height="240"
        loading="eager"
        decoding="async"
      />
      <h2>GBP Home Art & Decors</h2>
    </div>
    <p class="bio">
      We curate and provide functional and creative decor pieces that bring warmth, character, and elegance to every home. 
    </p>

    <nav id="hero-nav" aria-label="Primary navigation" class="hero-nav">
      <ul>
        {navLinks.map((link) => (
          <li>
            <a class="hero-nav-link" href={link.href}>{link.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</section>

<style>
  .hero {
    min-height: 82vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(180deg, rgba(7, 12, 38, 0.92), rgba(15, 24, 94, 0.64)),
      url('/images/GBP_HERO_BG.png');
    background-blend-mode: multiply;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    padding: 60px 20px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 15% 20%, rgba(255, 221, 136, 0.18), transparent 20%),
      radial-gradient(circle at 80% 80%, rgba(255, 255, 255, 0.12), transparent 18%);
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.06), transparent);
    animation: shine 8s linear infinite;
  }

  @keyframes shine {
    from { transform: translateX(-100%); }
    to { transform: translateX(100%); }
  }

  .hero-content {
    max-width: 900px;
    position: relative;
    z-index: 2;
    animation: grandEntrance 1.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .hero-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }

  .hero-logo {
    width: clamp(220px, 22vw, 320px);
    height: auto;
    display: block;
    object-fit: contain;
    background: transparent;
    transition: transform 0.35s ease, filter 0.35s ease;
    animation: glowPulse 7s ease-in-out infinite;
    filter: brightness(1.02) drop-shadow(0 0 28px rgba(255, 215, 0, 0.24));
  }

  .hero-logo:hover {
    transform: scale(1.06) rotate(-0.5deg);
    filter: brightness(1.1) drop-shadow(0 0 38px rgba(255, 215, 0, 0.32));
  }

  @keyframes glowPulse {
    0%, 100% {
      filter: brightness(1.02) drop-shadow(0 0 28px rgba(255, 215, 0, 0.24));
    }
    50% {
      filter: brightness(1.05) drop-shadow(0 0 36px rgba(255, 215, 0, 0.28));
    }
  }

  @keyframes grandEntrance {
    0% { opacity: 0; transform: translateY(80px) scale(0.92); filter: blur(12px); }
    100% { opacity: 1; transform: none; filter: none; }
  }

  .hero h2 {
    font-family: 'Playfair Display', serif;
    font-size: 65px;
    color: white;
    margin: 0;
    background: linear-gradient(90deg, #fff, #FFD978, #D4A64F, #fff);
    background-size: 300% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: glowFloat 6s ease-in-out infinite;
  }

  @keyframes glowFloat {
    0%, 100% { background-position: 0%; }
    50% { background-position: 100%; }
  }

  .bio {
    font-family: 'Playfair Display', 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(1.55rem, 2vw, 2.35rem);
    line-height: 1.8;
    font-weight: 500;
    color: #F6E7B8;
    letter-spacing: 0.01em;
    text-shadow: 0 1px 2px rgba(8, 14, 45, 0.18);
    background: linear-gradient(180deg, rgba(255, 250, 239, 0.24), rgba(255, 244, 226, 0.14));
    border: 1px solid rgba(212, 166, 79, 0.22);
    padding: 32px 34px;
    border-radius: 32px;
    backdrop-filter: blur(16px);
    box-shadow: 0 24px 74px rgba(15, 23, 75, 0.16);
    transition: transform 0.3s ease, background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
    overflow: hidden;
    animation: bioGlow 9s ease-in-out infinite alternate;
  }

  .bio:hover {
    transform: translateY(-4px) scale(1.01);
    background: linear-gradient(180deg, rgba(255, 251, 238, 0.34), rgba(255, 245, 229, 0.18));
    border-color: rgba(212, 166, 79, 0.36);
    box-shadow: 0 30px 90px rgba(15, 23, 75, 0.22);
  }

  @keyframes bioGlow {
    0% {
      box-shadow: 0 22px 68px rgba(15, 23, 75, 0.14);
      transform: translateY(0);
    }
    100% {
      box-shadow: 0 30px 90px rgba(15, 23, 75, 0.18);
      transform: translateY(-2px);
    }
  }

  .hero-nav {
    margin-top: 34px;
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .hero-nav ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 900px;
  }

  .hero-nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 18px;
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .hero-nav-link:hover,
  .hero-nav-link:focus {
    transform: translateY(-1px);
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .hero-nav-link.active {
    background: rgba(212, 166, 79, 0.18);
    border-color: #D4A64F;
    color: #FFD978;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 100vh;
    }

    .hero-content {
      padding: 0 12px;
    }

    .hero h2 {
      font-size: 38px;
    }

    .hero-logo {
      width: clamp(180px, 30vw, 220px);
    }

    .bio {
      font-size: 16px;
      padding: 18px;
    }

    .hero-nav {
      margin-top: 28px;
    }

    .hero-nav ul {
      gap: 10px;
    }

    .hero-nav-link {
      padding: 10px 16px;
      font-size: 13px;
    }
  }

  @media (max-width: 500px) {
    .hero h2 {
      font-size: 34px;
    }

    .hero-logo {
      width: clamp(160px, 40vw, 200px);
    }

    .hero-nav ul {
      justify-content: center;
    }

    .hero-nav-link {
      flex: 1 1 100%;
      max-width: 100%;
      border-radius: 999px;
    }
  }
</style>

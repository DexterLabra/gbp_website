---
const navLinks = [
  { href: "#", text: "Home" },
  { href: "#featured", text: "Featured Products" },
  { href: "#collections", text: "Collections" },
  { href: "#shipping", text: "Shipping" },
  { href: "#testimonials", text: "Client Feedback" },
  { href: "#contact", text: "Contact" },
];
---

<section class="hero" id="hero">
  <div class="hero-content">
    <h2>GBP Home Art & Decors</h2>
    <p class="bio">
      We curate and provide functional and creative decor pieces that bring warmth, character, and elegance to every home. ✨
    </p>

    <nav id="hero-nav" aria-label="Primary navigation" class="hero-nav">
      <ul>
        {navLinks.map((link) => (
          <li>
            <a class="hero-nav-link" href={link.href}>{link.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</section>

<style>
  .hero {
    min-height: 75vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(rgba(17, 29, 122, 0.85), rgba(17, 29, 122, 0.85)),
      url('https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=1500');
    background-size: cover;
    background-position: center;
    padding: 60px 20px;
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.06), transparent);
    animation: shine 8s linear infinite;
  }

  @keyframes shine {
    from { transform: translateX(-100%); }
    to { transform: translateX(100%); }
  }

  .hero-content {
    max-width: 900px;
    position: relative;
    z-index: 2;
    animation: grandEntrance 1.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  @keyframes grandEntrance {
    0% { opacity: 0; transform: translateY(80px) scale(0.92); filter: blur(12px); }
    100% { opacity: 1; transform: none; filter: none; }
  }

  .hero h2 {
    font-family: 'Playfair Display', serif;
    font-size: 65px;
    color: white;
    margin-bottom: 20px;
    background: linear-gradient(90deg, #fff, #FFD978, #D4A64F, #fff);
    background-size: 300% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: glowFloat 6s ease-in-out infinite;
  }

  @keyframes glowFloat {
    0%, 100% { background-position: 0%; }
    50% { background-position: 100%; }
  }

  .bio {
    font-size: 23px;
    line-height: 1.8;
    font-weight: 600;
    color: #FFD978;
    background: rgba(255, 255, 255, 0.08);
    padding: 25px;
    border-radius: 20px;
    backdrop-filter: blur(10px);
  }

  .hero-nav {
    margin-top: 34px;
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .hero-nav ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 900px;
  }

  .hero-nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 18px;
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .hero-nav-link:hover,
  .hero-nav-link:focus {
    transform: translateY(-1px);
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .hero-nav-link.active {
    background: rgba(212, 166, 79, 0.18);
    border-color: #D4A64F;
    color: #FFD978;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 100vh;
    }

    .hero-content {
      padding: 0 12px;
    }

    .hero h2 {
      font-size: 38px;
    }

    .bio {
      font-size: 16px;
      padding: 18px;
    }

    .hero-nav {
      margin-top: 28px;
    }

    .hero-nav ul {
      gap: 10px;
    }

    .hero-nav-link {
      padding: 10px 16px;
      font-size: 13px;
    }
  }

  @media (max-width: 500px) {
    .hero h2 {
      font-size: 34px;
    }

    .hero-nav ul {
      justify-content: center;
    }

    .hero-nav-link {
      flex: 1 1 100%;
      max-width: 100%;
      border-radius: 999px;
    }
  }
</style>

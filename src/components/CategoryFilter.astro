---
import { categories } from '../data/products';
---

<div class="filter-section">
  <div class="filter-panel">
    <h3 class="filter-title">Browse by Category</h3>
    <div class="select-wrap">
      <select id="categoryFilter" class="category-dropdown" aria-label="Choose a category">
        {categories.map((cat) => (
          <option value={cat.value}>{cat.label}</option>
        ))}
      </select>
      <span class="select-caret" aria-hidden="true">⌄</span>
    </div>
  </div>
</div>

<style>
  .filter-section {
    width: min(92%, 760px);
    margin: 22px auto 44px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .filter-panel {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 28px 24px;
    border-radius: 28px;
    backdrop-filter: blur(22px);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    box-shadow: 0 20px 44px var(--glass-shadow), inset 0 1px 0 rgba(255,255,255,0.16);
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    animation: panelRise 0.8s ease both;
  }

  .filter-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.18) 45%, transparent 100%);
    transform: translateX(-140%);
    transition: transform 0.8s ease;
    pointer-events: none;
  }

  .filter-panel:hover::before {
    transform: translateX(140%);
  }

  .filter-panel:hover {
    transform: translateY(-3px);
    box-shadow: 0 28px 56px var(--glass-shadow), inset 0 1px 0 rgba(255,255,255,0.22);
    border-color: rgba(255, 217, 120, 0.35);
  }

  .filter-title {
    font-family: 'Playfair Display', serif;
    color: var(--heading-color);
    font-size: clamp(1.35rem, 2.2vw, 1.7rem);
    margin: 0;
    letter-spacing: 0.02em;
    text-shadow: 0 1px 0 rgba(255,255,255,0.18);
  }

  .filter-title::before {
    content: '✦ ';
    display: inline-block;
    animation: iconFloat 2.2s ease-in-out infinite;
    color: var(--accent);
  }

  @keyframes iconFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-4px) scale(1.12); }
  }

  @keyframes panelRise {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .select-wrap {
    position: relative;
    width: min(100%, 320px);
  }

  .category-dropdown {
    width: 100%;
    padding: 15px 46px 15px 18px;
    border-radius: 999px;
    border: 1px solid rgba(212, 166, 79, 0.35);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    appearance: none;
    background: linear-gradient(135deg, var(--surface), var(--surface-alt));
    color: var(--page-text);
    box-shadow: 0 10px 24px rgba(212, 166, 79, 0.16), inset 0 1px 0 rgba(255,255,255,0.24);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease, background 0.3s ease;
  }

  .category-dropdown option {
    color: var(--page-text);
    background: var(--surface);
  }

  .select-caret {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    font-size: 18px;
    color: var(--accent);
    transition: transform 0.25s ease, color 0.25s ease;
  }

  .category-dropdown:hover,
  .category-dropdown:focus {
    transform: translateY(-2px) scale(1.01);
    box-shadow: 0 14px 30px rgba(212, 166, 79, 0.22), inset 0 1px 0 rgba(255,255,255,0.3);
    border-color: rgba(255, 217, 120, 0.6);
    outline: none;
  }

  .category-dropdown:focus + .select-caret {
    transform: translateY(-50%) rotate(180deg);
    color: var(--accent-strong);
  }

  .category-dropdown:focus {
    box-shadow: 0 0 0 3px rgba(212, 166, 79, 0.16), 0 16px 34px rgba(212, 166, 79, 0.24);
  }

  @media (max-width: 600px) {
    .filter-panel {
      padding: 24px 18px;
    }

    .category-dropdown {
      padding: 13px 42px 13px 16px;
      font-size: 14px;
    }
  }
</style>

---
import { contactLinks } from '../data/contact';
---

<section class="contact" id="contact">
  <div class="contact-shell">
    <div class="contact-intro">
      <p class="eyebrow">Connect With Us</p>
      <h2>We’re here to assist you</h2>

      <div class="contact-card">
        <div class="detail-row">
          <div class="detail-icon" aria-hidden="true">📞</div>
          <div class="detail-content">
            <span class="detail-label">Contact Number</span>
            <a href="tel:+639385576757">09385576757</a>
          </div>
        </div>

        <div class="detail-row">
          <div class="detail-icon" aria-hidden="true">🕒</div>
          <div class="detail-content">
            <span class="detail-label">Opening Hours</span>
            <span class="detail-value">8:00 AM - 5:00 PM every Monday - Saturday</span>
          </div>
        </div>

        <div class="detail-row address-row">
          <div class="detail-icon" aria-hidden="true">📍</div>
          <div class="detail-content">
            <span class="detail-label">Directions</span>
            <span class="detail-value">Metrogate Village, Block 23 Lot 11 63rd St, San Agustin 1, Dasmariñas, 4114 Cavite</span>
          </div>
        </div>

        <a
          class="direction-link"
          href="https://www.google.com/maps/place/GBP+Home+Art+%26+Decors+-+Cavite/@14.3027966,120.9393713,846m/data=!3m2!1e3!4b1!4m6!3m5!1s0x3397d5778cb7cc57:0x778e51fe49e290d1!8m2!3d14.3027966!4d120.9419462!16s%2Fg%2F11mf0h6c09?entry=ttu&g_ep=EgoyMDI2MDcxMy4wIKXMDSoASAFQAw%3D%3D"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="direction-icon" aria-hidden="true">🧭</span>
          <span>Get Direction</span>
        </a>
      </div>
    </div>

    <div class="contact-links">
      {contactLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer">
          <Fragment set:html={link.svg} /> {link.label}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    background: linear-gradient(135deg, var(--surface-strong), var(--surface-alt));
    padding: 120px 20px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--page-text);
    overflow: hidden;
  }

  .contact::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top left, rgba(212, 166, 79, 0.18), transparent 30%),
      radial-gradient(circle at bottom right, rgba(17, 29, 122, 0.16), transparent 28%);
    pointer-events: none;
  }

  .contact-shell {
    max-width: 900px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .contact-intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.34em;
    font-size: 0.84rem;
    font-weight: 800;
    color: var(--accent);
    text-shadow: 0 0 20px rgba(212, 166, 79, 0.2);
  }

  .contact h2 {
    color: var(--heading-color);
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 3.6vw, 3rem);
    margin: 0;
    letter-spacing: 0.02em;
    text-shadow: 0 2px 24px rgba(16, 35, 94, 0.12);
  }

  .contact-card {
    width: 100%;
    max-width: 780px;
    padding: 30px 32px;
    border-radius: 30px;
    border: 1px solid rgba(212, 166, 79, 0.28);
    background: var(--glass-bg);
    box-shadow: 0 24px 64px var(--glass-shadow);
    backdrop-filter: blur(22px);
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: left;
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .contact-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(125deg, rgba(212, 166, 79, 0.7), rgba(255, 255, 255, 0.26), rgba(17, 29, 122, 0.36));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .contact-card::after {
    content: '';
    position: absolute;
    inset: -30% auto auto -10%;
    width: 45%;
    height: 140%;
    background: linear-gradient(120deg, transparent, rgba(255, 255, 255, 0.34), transparent);
    transform: rotate(12deg) translateX(-160%);
    pointer-events: none;
    animation: shineSweep 5.6s ease-in-out infinite;
  }

  .detail-row {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    border-radius: 18px;
    border: 1px solid rgba(212, 166, 79, 0.16);
    background: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transition: transform 0.28s ease, box-shadow 0.28s ease, background 0.28s ease, border-color 0.28s ease;
  }

  .detail-row:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 34px rgba(16, 35, 94, 0.12);
    background: rgba(255, 255, 255, 0.16);
    border-color: rgba(212, 166, 79, 0.3);
  }

  .detail-icon {
    width: 50px;
    height: 50px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 15px;
    font-size: 1.2rem;
    color: var(--button-text);
    background: linear-gradient(135deg, rgba(212, 166, 79, 0.94), rgba(255, 217, 120, 0.92));
    box-shadow: 0 10px 24px rgba(212, 166, 79, 0.24);
    flex-shrink: 0;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .detail-row:hover .detail-icon {
    transform: scale(1.04);
    box-shadow: 0 14px 28px rgba(212, 166, 79, 0.3);
  }

  .detail-content {
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-width: 0;
  }

  .detail-label {
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .detail-row a,
  .detail-row .detail-value {
    color: var(--page-text);
    font-size: 1.04rem;
    line-height: 1.7;
    font-weight: 700;
  }

  .detail-row a {
    text-decoration: none;
    font-weight: 800;
    color: var(--heading-color);
    position: relative;
    display: inline-block;
  }

  .detail-row a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0.2);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .detail-row a:hover::after {
    transform: scaleX(1);
  }

  .detail-row a:hover {
    color: var(--accent);
  }

  .direction-link {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    margin-top: 6px;
    padding: 13px 20px;
    border-radius: 999px;
    text-decoration: none;
    color: var(--button-text);
    font-weight: 800;
    letter-spacing: 0.03em;
    background: linear-gradient(135deg, rgba(212, 166, 79, 0.95), rgba(255, 217, 120, 0.9));
    box-shadow: 0 14px 28px rgba(16, 35, 94, 0.14);
    transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
  }

  .direction-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 34px rgba(16, 35, 94, 0.2);
    filter: brightness(1.04);
  }

  .direction-link:active {
    transform: translateY(0);
  }

  .direction-icon {
    font-size: 1rem;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .contact-links a {
    text-decoration: none;
    color: var(--page-text);
    font-size: 1rem;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: transform 0.3s ease, background 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
    padding: 14px 22px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.14);
  }

  .contact-links a:hover {
    transform: translateY(-6px);
    background: var(--accent);
    color: var(--button-text);
    box-shadow: 0 12px 24px rgba(16, 35, 94, 0.16);
  }

  @keyframes shineSweep {
    0% {
      transform: rotate(12deg) translateX(-180%);
      opacity: 0;
    }
    30% {
      opacity: 0.9;
    }
    100% {
      transform: rotate(12deg) translateX(220%);
      opacity: 0;
    }
  }

  .contact-links a :global(svg) {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .contact {
      padding: 90px 18px;
    }

    .contact-card {
      padding: 20px;
    }
  }
</style>

---
import { contactLinks } from '../data/contact';
---

<section class="contact" id="contact">
  <h2>Connect With Us</h2>
  <div class="contact-links">
    {contactLinks.map((link) => (
      <a href={link.href} target="_blank" rel="noopener noreferrer">
        <Fragment set:html={link.svg} /> {link.label}
      </a>
    ))}
  </div>
</section>

<style>
  .contact {
    background: #111D7A;
    padding: 120px 20px;
    min-height: 80vh;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .contact h2 {
    color: #D4A64F;
    font-family: 'Playfair Display', serif;
    font-size: 40px;
    margin-bottom: 35px;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 25px;
  }

  .contact-links a {
    text-decoration: none;
    color: white;
    font-size: 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: 0.3s;
    padding: 14px 24px;
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.08);
  }

  .contact-links a:hover {
    transform: translateY(-8px);
    background: #D4A64F;
    color: #111D7A;
  }

  .contact-links a :global(svg) {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }
</style>
